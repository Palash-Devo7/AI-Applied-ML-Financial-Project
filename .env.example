# ── LLM Provider (deepseek or claude) ────────────────────────────────────────
LLM_PROVIDER=deepseek

# ── DeepSeek (default — much cheaper than Claude) ─────────────────────────────
DEEPSEEK_API_KEY=sk-
DEEPSEEK_MODEL=deepseek-chat

# ── Claude / Anthropic (optional — set LLM_PROVIDER=claude to use) ────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Finance AI RAG"
APP_VERSION="1.0.0"
ENVIRONMENT=development   # development | staging | production
DEBUG=true
LOG_LEVEL=INFO

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# ── Claude / Anthropic ────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_TEMPERATURE=0.1
CLAUDE_MAX_TOKENS=2048

# ── Embeddings (ProsusAI/finbert) ─────────────────────────────────────────────
EMBEDDING_MODEL=ProsusAI/finbert
EMBEDDING_STRATEGY=cls   # cls | mean
EMBEDDING_BATCH_SIZE=16
EMBEDDING_DEVICE=cpu     # cpu | cuda

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=finance_docs
CHROMA_DISTANCE_FUNCTION=cosine

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_FETCH_MULTIPLIER=2
RETRIEVAL_RRF_ALPHA=0.7
MAX_CONTEXT_TOKENS=6000

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE_TOKENS=480
CHUNK_OVERLAP_TOKENS=64


FINETUNED_MODEL_PATH=

# ── Monitoring ────────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
METRICS_PREFIX=finance_rag

# ── Grafana (docker-compose only) ─────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme
